rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasUserDoc() && userData().role == 'admin';
    }

    function isTeacher() {
      return hasUserDoc() && userData().role in ['admin', 'teacher'];
    }

    function isStudent() {
      return hasUserDoc() && userData().role == 'student';
    }

    // ユーザー（生徒追加・assignedTeacherIds 更新は管理者のみ）
    match /users/{userId} {
      allow read: if isTeacher() || (signedIn() && request.auth.uid == userId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // 受講登録（作成・更新は管理者。生徒は自分のレコードのみ読取）
    match /enrollments/{enrollmentId} {
      allow read: if isTeacher() ||
        (isStudent() && resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // プライベート枠
    match /privateSlots/{slotId} {
      allow read: if isTeacher() || isStudent();
      allow create: if isAdmin() || (isTeacher() && request.resource.data.teacherId == request.auth.uid);
      allow update, delete: if isAdmin() ||
        (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // プライベート予約
    match /privateBookings/{bookingId} {
      allow read: if isTeacher() ||
        (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isAdmin() ||
        (isStudent() && request.resource.data.studentId == request.auth.uid);
      allow update, delete: if isAdmin() || isTeacher() ||
        (isStudent() && resource.data.studentId == request.auth.uid);
    }

    // お知らせ
    match /announcements/{id} {
      allow read: if isTeacher() || isStudent();
      allow write: if isAdmin();
    }

    // 教師プロフィール
    match /teacherProfiles/{teacherId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() ||
        (isTeacher() && request.auth.uid == teacherId);
    }

    // 設定（管理画面）
    match /settings/{docId} {
      allow read: if isTeacher();
      allow write: if isAdmin();
    }

    // メッセージスレッド
    match /threads/{threadId} {
      allow read, write: if isTeacher();

      match /messages/{messageId} {
        allow read, write: if isTeacher();
      }
    }

    // 旧ドキュメント互換（使っていれば）
    match /sessions/{sessionId} {
      allow read, write: if isTeacher();
    }

    match /bookings/{bookingId} {
      allow read, write: if isTeacher();
    }

    match /attendance/{id} {
      allow read, write: if isTeacher();
    }

    match /students/{studentId} {
      allow read: if isTeacher();
      allow write: if isAdmin();
    }
  }
}

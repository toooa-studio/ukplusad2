rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasUserDoc() && userData().role == 'admin';
    }

    // admin + teacher（管理画面・講師画面スタッフ）
    function isTeacher() {
      return hasUserDoc() && userData().role in ['admin', 'teacher'];
    }

    function isStudent() {
      return hasUserDoc() && userData().role == 'student';
    }

    // ユーザー（生徒追加・assignedTeacherIds 更新は管理者のみ）
    match /users/{userId} {
      allow read: if isTeacher() || (signedIn() && request.auth.uid == userId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // 受講登録（作成・削除は管理者。生徒は自分のレコードの読取＋予約時の残数消費更新）
    match /enrollments/{enrollmentId} {
      allow read: if isTeacher() ||
        (isStudent() && resource.data.studentId == request.auth.uid);
      allow create, delete: if isAdmin();
      // 予約時、生徒アプリが自分の受講登録（残数）を直接消費するため update を許可。
      allow update: if isAdmin() ||
        (isStudent() && resource.data.studentId == request.auth.uid &&
          request.resource.data.studentId == request.auth.uid);
    }

    // プライベート枠
    match /privateSlots/{slotId} {
      allow read: if isTeacher() || isStudent();
      // 生徒アプリは予約時に枠の分割（前後の空き枠）を作成するため create を許可。
      allow create: if isAdmin() ||
        (isTeacher() && request.resource.data.teacherId == request.auth.uid) ||
        isStudent();
      // 生徒アプリは予約時に枠を booked に更新するため update を許可。
      allow update: if isAdmin() ||
        (isTeacher() && resource.data.teacherId == request.auth.uid) ||
        isStudent();
      allow delete: if isAdmin() ||
        (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // プライベート / セミプライベート予約
    match /privateBookings/{bookingId} {
      // 教師は全件読取可能。生徒は自分が代表者 or 参加者として含まれる予約のみ読取可能。
      // NOTE: `attendeeStudentIds array-contains uid` クエリを許可するため、
      //       型ガード (is list) は付けず、条件を OR で分離する。
      //       型ガードを付けると Firestore が array-contains クエリを静的検証できず拒否する。
      allow read: if isTeacher()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isStudent() && request.auth.uid in resource.data.attendeeStudentIds);
      // 生徒からの作成は自分が代表者 or 参加者として含まれる場合のみ。
      // 通常はサーバー側 (Admin SDK) で作成する想定。
      allow create: if isAdmin()
        || (isStudent() && request.resource.data.studentId == request.auth.uid)
        || (isStudent() && request.auth.uid in request.resource.data.attendeeStudentIds);
      allow update, delete: if isAdmin() || isTeacher()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || (isStudent() && request.auth.uid in resource.data.attendeeStudentIds);
    }

    // 生徒グループ（セミプライベートのペア事前登録）
    // 管理者のみが作成・編集・削除可能。
    // 講師は全件読取、生徒はメンバーである自分のグループのみ読取可能。
    match /studentGroups/{groupId} {
      // `memberIds array-contains uid` クエリを許可するため型ガードは付けない。
      allow read: if isTeacher()
        || (isStudent() && request.auth.uid in resource.data.memberIds);
      allow create, update, delete: if isAdmin();
    }

    // お知らせ
    match /announcements/{id} {
      allow read: if isTeacher() || isStudent();
      allow write: if isAdmin();
    }

    // 教師プロフィール
    match /teacherProfiles/{teacherId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() ||
        (isTeacher() && request.auth.uid == teacherId);
    }

    // 設定（管理画面）
    match /settings/{docId} {
      allow read: if isTeacher();
      allow write: if isAdmin();
    }

    // メッセージスレッド
    match /threads/{threadId} {
      allow read, write: if isTeacher();

      match /messages/{messageId} {
        allow read, write: if isTeacher();
      }
    }

    // 旧ドキュメント互換（使っていれば）
    match /sessions/{sessionId} {
      allow read, write: if isTeacher();
    }

    match /bookings/{bookingId} {
      allow read, write: if isTeacher();
    }

    match /attendance/{id} {
      allow read, write: if isTeacher();
    }

    match /students/{studentId} {
      allow read: if isTeacher();
      allow write: if isAdmin();
    }
  }
}
